# Copiar a .env local o usar los mismos nombres en Railway (servicio rail-cucuru).
# CRESIUM_TENANT_ID = UUID de core.tenants.id (mismo tenant que tus usuarios en core.users).
# Valor por defecto del seed (Tenant por defecto / constanza-default):
CRESIUM_TENANT_ID=00000000-0000-0000-0000-000000000001

DATABASE_URL=postgresql://user:pass@host:5432/dbname
CRESIUM_PARTNER_SECRET=poner_el_secret_de_cresium
# REDIS_URL=redis://...
# CRESIUM_COMPANY_ID=
# CRESIUM_TIMESTAMP_UNIT=auto   # auto | seconds | milliseconds
# CRESIUM_REPLAY_WINDOW_MS=900000  # 15 min por defecto en código
